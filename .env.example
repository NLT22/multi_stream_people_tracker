# RAG / Ask agent config. Copy this file to `.env` and fill in a key.
# `.env` is gitignored (never committed); this .example is the tracked template.
# The agent auto-loads .env from the repo root (src/rag/agent.py::_load_dotenv).

# Pick the model — its name selects the provider:
#   gpt-4o, gpt-4o-mini, o3-mini ... -> OpenAI  (needs OPENAI_API_KEY)
#   claude-sonnet-4-6, claude-*      -> Anthropic (needs ANTHROPIC_API_KEY)
RAG_MODEL=gpt-4o

# Set the key for whichever provider RAG_MODEL points to (leave the other blank).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
